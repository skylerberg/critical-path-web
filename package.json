{
  "name": "game-dev-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    },
    "workbox-build": {
      "glob": "^13.0.6"
    },
    "source-map@^0.8.0-beta.0": "0.7.6",
    "@redocly/openapi-core": {
      "js-yaml": "4.3.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:api": "node scripts/generate-api-types.mjs",
    "prepare": "node scripts/setup-hooks.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@tiptap/core": "~3.27.3",
    "@tiptap/extension-image": "~3.27.3",
    "@tiptap/extensions": "~3.27.3",
    "@tiptap/starter-kit": "~3.27.3",
    "openapi-fetch": "~0.17.0",
    "svelte": "~5.56.4",
    "svelte-dnd-action": "0.9.70"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "~7.2.0",
    "@tailwindcss/vite": "~4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "~5.4.2",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "~3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "~7.13.0",
    "prettier": "~3.8.5",
    "prettier-plugin-svelte": "~4.1.1",
    "svelte-check": "~4.7.2",
    "tailwindcss": "~4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "~8.63.0",
    "vite": "~8.1.3",
    "vite-plugin-pwa": "~1.3.0",
    "vitest": "~4.1.10"
  }
}
